{
    "include": [],
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "isolatedModules": true,
        "noEmitOnError": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "stripInternal": true,
        "ignoreDeprecations": "6.0"
    }
}
