{
    "name": "@solana/spl-token",
    "version": "0.4.15",
    "description": "SPL Token Program JS API",
    "homepage": "https://github.com/solana-program/token-2022#readme",
    "bugs": {
        "url": "https://github.com/solana-program/token-2022/issues"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solana-program/token-2022.git"
    },
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=20.18.0"
    },
    "files": [
        "lib",
        "src",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "./lib/cjs/index.js",
    "module": "./lib/esm/index.js",
    "types": "./lib/types/index.d.ts",
    "exports": {
        "types": "./lib/types/index.d.ts",
        "require": "./lib/cjs/index.js",
        "import": "./lib/esm/index.js"
    },
    "scripts": {
        "prepublishOnly": "pnpm build",
        "nuke": "shx rm -rf node_modules pnpm-lock.yaml || true",
        "reinstall": "pnpm run nuke && pnpm install",
        "clean": "shx rm -rf lib **/*.tsbuildinfo || true",
        "build": "tsc --build --verbose tsconfig.all.json",
        "typecheck": "tsc --noEmit",
        "postbuild": "shx echo '{ \"type\": \"commonjs\" }' > lib/cjs/package.json",
        "watch": "tsc --build --verbose --watch tsconfig.all.json",
        "release": "pnpm run clean && pnpm run build",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "format": "oxfmt --check src test",
        "format:fix": "oxfmt src test",
        "example": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/createMintAndTransferTokens.ts",
        "start-local-validator": "./start-local-validator.sh",
        "test": "pnpm run test:unit && pnpm run test:e2e-native && pnpm run test:e2e-2022",
        "test:unit": "vitest run --dir test/unit",
        "test:e2e-native": "vitest run --dir test/e2e",
        "test:e2e-2022": "TEST_PROGRAM_ID=TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb vitest run --dir test/e2e && TEST_PROGRAM_ID=TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb vitest run --dir test/e2e-2022",
        "deploy": "pnpm run deploy:docs",
        "docs": "shx rm -rf docs && typedoc && shx cp .nojekyll docs/",
        "deploy:docs": "pnpm run docs && gh-pages --dest token/js --dist docs --dotfiles"
    },
    "peerDependencies": {
        "@solana/web3.js": "3.0.0-rc.2"
    },
    "dependencies": {
        "@solana/kit": "^6.10.0",
        "buffer": "^6.0.3",
        "@solana-program/token": "^0.14.0",
        "@solana-program/token-2022": "^0.12.0"
    },
    "devDependencies": {
        "@solana/codecs-strings": "7.0.0",
        "@solana/spl-memo": "0.2.5",
        "@solana/web3.js": "3.0.0-rc.2",
        "@types/node": "^26.0.0",
        "@types/node-fetch": "^2.6.12",
        "gh-pages": "^6.3.0",
        "oxfmt": "0.58.0",
        "oxlint": "^1.73.0",
        "process": "^0.11.10",
        "shx": "^0.4.0",
        "ts-node": "^10.9.2",
        "typedoc": "^0.28.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10"
    }
}
